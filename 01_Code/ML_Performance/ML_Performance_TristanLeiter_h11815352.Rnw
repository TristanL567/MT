\section{Feature Importance Analysis}

\subsection{M3 Top Features (after label shift + rolling peak fix)}

\begin{table}[H]
\centering
\caption{Top 10 Features by Gain — M3 XGBoost (Raw)}
\rowcolors{2}{gray!10}{white}
\begin{tabular}{clrl}
\toprule
\textbf{Rank} & \textbf{Feature} & \textbf{Gain} & \textbf{Interpretation} \\
\midrule
1 & \texttt{max\_dd\_12m} & 36.6\% & Current drawdown severity (3-yr rolling peak) \\
2 & \texttt{altman\_z2} & 14.0\% & Retained earnings / assets \\
3 & \texttt{ocf\_per\_share} & 4.3\% & Operating cash flow per share \\
4 & \texttt{ann\_return} & 3.6\% & Annual price return \\
5 & \texttt{roll\_mean\_5y\_earn\_yld} & 3.2\% & 5-yr avg earnings yield \\
6 & \texttt{roll\_min\_3y\_earn\_yld} & 2.3\% & Worst earnings yield in 3-yr window \\
\bottomrule
\end{tabular}
\end{table}

\noindent \textit{Note:} Before the label shift correction, \texttt{max\_dd\_12m} dominated 
at 90.7\% gain — near-tautological contemporaneous leakage. After the shift, 
gain concentration dropped to 36.6\%, and the model uses a broad fundamental signal set.

