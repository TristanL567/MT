%==============================================================================
\chapter{Variational Autoencoder}
\label{ch:vae}
%==============================================================================

\section{Architecture and Motivation}

A \textbf{Beta-VAE} with an optional supervised classification head is implemented 
in Python (PyTorch) as \texttt{08B\_Autoencoder.py}. The VAE serves two functions:

\begin{enumerate}
    \item \textbf{Dimensionality reduction:} Compresses the $\sim$452 (fund) or $\sim$471 (raw) 
    dimensional input vector $x$ into a 24-dimensional latent representation $z$, 
    capturing non-linear structural dependencies that linear PCA would miss.
    
    \item \textbf{Anomaly detection feature:} The per-firm reconstruction error 
    $\mathcal{L}_{\text{recon}} = ||x - \hat{x}||^2$ serves as an explicit feature 
    in the downstream classifier. CSI firms that deviate from the ``healthy manifold'' 
    produce higher reconstruction errors.
\end{enumerate}

\subsection{Architecture Details}

\begin{table}[H]
\centering
\caption{VAE Architecture}
\rowcolors{2}{gray!10}{white}
\begin{tabular}{ll}
\toprule
\textbf{Component} & \textbf{Specification} \\
\midrule
Encoder & Input $\rightarrow$ 256 $\rightarrow$ 128 $\rightarrow$ 64 $\rightarrow$ $(z_\mu, z_{\log\sigma^2})$ \\
Decoder & $z$ $\rightarrow$ 64 $\rightarrow$ 128 $\rightarrow$ 256 $\rightarrow$ output \\
Classifier head & $z_\mu$ $\rightarrow$ 16 $\rightarrow$ logit (optional, $\gamma = 0.1$) \\
Activation & LayerNorm + GELU \\
$z$ dimension & 24 \\
Parameters (fund) & 321,557 \\
Parameters (raw) & 331,304 \\
\bottomrule
\end{tabular}
\end{table}

\section{Corrected ELBO Loss}

The loss function is the corrected Evidence Lower BOund (ELBO):

\begin{equation}
    \mathcal{L}_{\text{total}} = \mathcal{L}_{\text{recon}} + \beta \cdot \mathcal{L}_{\text{KL}} + \gamma \cdot \mathcal{L}_{\text{clf}}
\end{equation}

\noindent Key corrections vs a naive implementation:

\begin{enumerate}
    \item \textbf{Loss reduction:} \texttt{reduction="none"} followed by 
    \texttt{.sum(dim=1).mean()} — sums reconstruction error over the feature dimension 
    first, then averages over the batch. This ensures $\mathcal{L}_{\text{recon}}$ and 
    $\mathcal{L}_{\text{KL}}$ are on the same scale, preventing posterior collapse.
    
    \item \textbf{PIT normalisation:} \texttt{output\_distribution="normal"} (not uniform). 
    Normal targets match the linear decoder's unbounded output range and align with 
    Gaussian generative assumptions.
    
    \item \textbf{Early stopping on validation loss:} 15\% of training data held out for 
    early stopping; best weights restored on validation loss minimum.
    
    \item \textbf{Numerically stable classification loss:} Classifier head returns raw 
    logits; \texttt{BCEWithLogitsLoss} applied (log-sum-exp trick).
\end{enumerate}

\section{Training Results}

Both VAE runs (fund and raw inputs) completed 150 epochs without early stopping, 
with tight train/validation gaps indicating no overfitting.

\begin{table}[H]
\centering
\caption{VAE Latent Space Diagnostics}
\rowcolors{2}{gray!10}{white}
\begin{tabular}{lcc}
\toprule
\textbf{Metric} & \textbf{VAE-Fund (M2)} & \textbf{VAE-Raw (M4)} \\
\midrule
Input features & 452 & 471 \\
Active dims (var $\geq 10^{-3}$) & \textbf{24 / 24} & \textbf{24 / 24} \\
Collapsed dims & 0 & 0 \\
Dim variance range & {[}0.83, 1.20{]} & {[}0.85, 1.19{]} \\
Recon error — CSI firms & 0.4951 & 0.5124 \\
Recon error — Non-CSI firms & 0.3231 & 0.3320 \\
\textbf{Ratio (CSI / Non-CSI)} & \textbf{1.532} & \textbf{1.543} \\
Test recon error p95 & 0.8874 & 0.9013 \\
\bottomrule
\end{tabular}
\end{table}

\subsection{Key Finding: Anomaly Signal Confirmed}

Both VAEs achieve a CSI/Non-CSI reconstruction error ratio $> 1.5$, confirming that 
the latent space has learned genuine anomaly structure. CSI firms are reconstructed 
$\approx 53\%$ worse than healthy firms, validating the Autoencoder hypothesis 
from Sub-Question 1. The ratio is marginally higher for the raw VAE (1.543 vs 1.532), 
consistent with price drawdown features providing additional distress signal.

\subsection{What Worked Well}

\begin{itemize}
    \item \textbf{LayerNorm + GELU:} Superior to BatchNorm + ReLU for financial tabular 
    data. LayerNorm normalises within each observation rather than across the batch, 
    appropriate for high between-firm variance in financial ratios.
    
    \item \textbf{KL warmup ($\beta$ ramp over 20 epochs):} Prevents the encoder from 
    collapsing to the prior before the decoder has learned to reconstruct. 
    Zero collapsed dimensions in both runs.
    
    \item \textbf{Gradient clipping (max\_norm=1.0):} Stabilises training in 
    early epochs when loss gradients are large.
    
    \item \textbf{Stratified train/val split:} Ensures class balance in the 
    validation set used for early stopping.
    
    \item \textbf{Median imputation + winsorisation before PIT:} Converts Inf values 
    to NaN, winsorises at 0.1\%/99.9\% of training distribution, then imputes with 
    training medians. Prevents overflow in float32 tensors.
\end{itemize}

%==============================================================================
\chapter{Manual XGBoost Training}
\label{ch:xgboost}
%==============================================================================

\section{Overview}

XGBoost models are trained via \texttt{09\_Train.R} using Bayesian hyperparameter 
optimisation (HPO) with an expanding window CV objective. Two classifiers are 
trained for each feature set: the hand-tuned XGBoost here, and the AutoGluon 
ensemble in Chapter~\ref{ch:autogluon}.

\section{Bayesian HPO Design}

\begin{itemize}
    \item \textbf{Algorithm:} Bayesian Optimisation with Upper Confidence Bound 
    (UCB, $\kappa = 2.576$) acquisition function via \texttt{rBayesianOptimization}
    \item \textbf{Iterations:} 10 random initialisation + 20 Bayesian = 30 total
    \item \textbf{Objective:} Maximise CV AUCPR (\texttt{eval\_metric = "aucpr"})
    \item \textbf{Class imbalance:} \texttt{scale\_pos\_weight = n\_neg / n\_pos $\approx$ 8.94}
    \item \textbf{Nrounds:} 500 during HPO (early stopping at 20), 
    1000 during final model (early stopping at 50)
\end{itemize}

\subsection{HPO Search Space}

\begin{table}[H]
\centering
\caption{Bayesian HPO Hyperparameter Bounds}
\rowcolors{2}{gray!10}{white}
\begin{tabular}{lll}
\toprule
\textbf{Parameter} & \textbf{Lower Bound} & \textbf{Upper Bound} \\
\midrule
\texttt{eta} (learning rate) & 0.01 & 0.30 \\
\texttt{max\_depth} & 3 & 8 \\
\texttt{subsample} & 0.50 & 1.00 \\
\texttt{colsample\_bytree} & 0.50 & 1.00 \\
\texttt{min\_child\_weight} & 1 & 20 \\
\texttt{gamma} & 0.00 & 5.00 \\
\texttt{lambda} (L2) & 0.00 & 5.00 \\
\texttt{alpha} (L1) & 0.00 & 5.00 \\
\bottomrule
\end{tabular}
\end{table}

\section{Best HPO Configurations}

\subsection{M3 (Raw Features) — Optimal Parameters}

\begin{itemize}
    \item \texttt{eta = 0.019}, \texttt{max\_depth = 5}, \texttt{subsample = 0.50}
    \item \texttt{colsample\_bytree = 0.50}, \texttt{min\_child\_weight = 4}
    \item \texttt{gamma = 4.4}, \texttt{lambda = 5.0}, \texttt{alpha = 2.7}
    \item Optimal rounds: 110, CV AUCPR: \textbf{0.4855} (original run) / \textbf{0.5434} (revised 4-fold)
\end{itemize}

\subsection{M1 (Fundamentals Only) — Optimal Parameters}

\begin{itemize}
    \item \texttt{eta = 0.010}, \texttt{max\_depth = 3}, \texttt{subsample = 0.52}
    \item \texttt{colsample\_bytree = 0.86}, \texttt{min\_child\_weight = 10}
    \item \texttt{gamma = 3.31}, \texttt{lambda} $\approx 0$, \texttt{alpha = 1.39}
    \item Optimal rounds: 115, CV AUCPR: \textbf{0.4369}
\end{itemize}

\noindent The M1 optimal configuration is shallower (\texttt{max\_depth = 3} vs 5 for M3) 
and more regularised, consistent with fewer informative features when price signals are removed.

